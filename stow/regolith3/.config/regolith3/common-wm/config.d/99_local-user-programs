# KeePassXC reads DPI via XSETTINGS once at launch, so wait for gsd-xsettings
# to start and publish its settings before launching.
exec --no-startup-id sh -c 'until pgrep -x gsd-xsettings >/dev/null; do sleep 0.1; done; sleep 1; keepassxc'
exec --no-startup-id workrave

# Enable touchscreen gesture support in Firefox via XInput2.
exec --no-startup-id systemctl --user set-environment MOZ_USE_XINPUT2=1

# Gnome keyring starts without DISPLAY being set, which prevents SSH key usage
# confirmation from working. Reloading the keyring will have DISPLAY set but
# will require the keyring to be unlocked again.
exec --no-startup-id gnome-keyring-daemon --replace

exec --no-startup-id /usr/libexec/geoclue-2.0/demos/agent

exec_always --no-startup-id gsettings set org.gnome.desktop.peripherals.keyboard delay 'uint32 250'
exec_always --no-startup-id gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 'uint32 33'
# gsd-keyboard does not reapply keyboard settings after XKB init resets X11
# state. xset is a no-op under Wayland.
exec_always --no-startup-id sh -c 'until pgrep -x gsd-keyboard >/dev/null; do sleep 0.1; done; sleep 1; xset r rate 250 33'

# gsd-keyboard resets the X core bell as a side effect of XKB init. xset is a
# no-op under Wayland.
exec_always --no-startup-id sh -c 'until pgrep -x gsd-keyboard >/dev/null; do sleep 0.1; done; sleep 1; xset b off'

# Regenerate Alacritty's theme import from the active Regolith look.
# regolith-look refresh triggers a WM reload, so exec_always rebuilds
# this whenever the look changes.
exec_always --no-startup-id ~/usr/bin/regolith-look-to-alacritty
