#!/usr/bin/env bash
# Emit an Alacritty TOML fragment derived from the currently-loaded Regolith
# look: gnome.terminal.color{0..15} for colors and gnome.terminal.font for
# the monospace font family and size.
#
# Intended to be imported from alacritty.toml via `[general].import`.
#
# Usage:
#   regolith-look-to-alacritty > ~/.config/alacritty/regolith-look.toml
set -euo pipefail

main() {
  local -A c=()
  local key val n

  while read -r key val; do
    n="${key#gnome.terminal.}"
    n="${n%:}"
    c["${n}"]="${val}"
  done < <(xrdb -query | grep '^gnome\.terminal\.color[0-9]\+:')

  for n in color{0..15}; do
    if [[ -z "${c[${n}]:-}" ]]; then
      echo "error: gnome.terminal.${n} is not set in the X resources database;" \
           "is a Regolith look loaded?" >&2
      exit 1
    fi
  done

  # Font: GTK/Pango descriptor "Family Name Size" where the trailing integer
  # (or decimal) is the point size and everything before it is the family.
  local font_raw family size
  font_raw="$(xrdb -query | awk -F':[[:space:]]+' '$1 == "gnome.terminal.font" { print $2; exit }')"
  if [[ "${font_raw}" =~ ^(.+)[[:space:]]+([0-9]+(\.[0-9]+)?)$ ]]; then
    family="${BASH_REMATCH[1]}"
    size="${BASH_REMATCH[2]}"
    [[ "${size}" != *.* ]] && size="${size}.0"
  else
    family=""
    size=""
    [[ -n "${font_raw}" ]] && \
      echo "warning: could not parse gnome.terminal.font=${font_raw@Q}; skipping font" >&2
  fi

  cat <<EOF
# Generated by regolith-look-to-alacritty from the currently-loaded Regolith
# look. Re-run after switching looks or editing the look's palette or font.

[colors.primary]
background = "${c[color0]}"
foreground = "${c[color7]}"

[colors.normal]
black   = "${c[color0]}"
red     = "${c[color1]}"
green   = "${c[color2]}"
yellow  = "${c[color3]}"
blue    = "${c[color4]}"
magenta = "${c[color5]}"
cyan    = "${c[color6]}"
white   = "${c[color7]}"

[colors.bright]
black   = "${c[color8]}"
red     = "${c[color9]}"
green   = "${c[color10]}"
yellow  = "${c[color11]}"
blue    = "${c[color12]}"
magenta = "${c[color13]}"
cyan    = "${c[color14]}"
white   = "${c[color15]}"
EOF

  if [[ -n "${family}" ]]; then
    cat <<EOF

[font]
size = ${size}

[font.normal]
family = "${family}"
EOF
  fi
}
main "$@"
