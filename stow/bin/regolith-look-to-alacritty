#!/usr/bin/env bash
# Regenerate ~/.config/alacritty/regolith-look.toml from the active Regolith
# look's Xresource files. Written atomically so Alacritty's file watcher never
# reads a partial file.
#
# Intended to be imported from alacritty.toml via `[general].import`.
set -euo pipefail

OUTPUT="${HOME}/.config/alacritty/regolith-look.toml"

XRESOURCES="${HOME}/.config/regolith3/Xresources"
XRESOURCES_SEARCH_PATH="${HOME}/.config/regolith3/Xresources.d"

# Resolve all #define macros from an Xresource file, recursing into #include.
# Populates the associative array named by $1.
# Include paths are resolved relative to the including file first, then
# relative to XRESOURCES_SEARCH_PATH (mirroring xrdb's -I flag behavior).
load_defines() {
  local -n _defs="$1"
  local file="$2"
  local base_dir
  base_dir="$(dirname "${file}")"
  local line

  while IFS= read -r line; do
    if [[ "${line}" =~ ^#define[[:space:]]+([^[:space:]]+)[[:space:]]+(.+)$ ]]; then
      _defs["${BASH_REMATCH[1]}"]="${BASH_REMATCH[2]}"
    elif [[ "${line}" =~ ^#include[[:space:]]\"([^\"]+)\" ]]; then
      local inc="${BASH_REMATCH[1]}"
      local inc_path="${base_dir}/${inc}"
      if [[ ! -f "${inc_path}" ]]; then
        inc_path="${XRESOURCES_SEARCH_PATH}/${inc}"
      fi
      load_defines "$1" "${inc_path}"
    fi
  done < "${file}"
}

# Resolve a value: if it matches a key in the define map, return its value
# (recursing until stable); otherwise return the value as-is.
resolve() {
  local -n _defs="$1"
  local val="$2"
  local seen=()
  while [[ -n "${_defs[${val}]+_}" ]]; do
    for s in "${seen[@]+"${seen[@]}"}"; do
      [[ "${s}" == "${val}" ]] && break 2
    done
    seen+=("${val}")
    val="${_defs[${val}]}"
  done
  printf '%s' "${val}"
}

generate() {
  # Find the active look directory from the top-level Xresources file.
  local look_path
  look_path="$(awk -F':[[:space:]]+' '$1 == "regolith.look.path" { print $2; exit }' \
    "${XRESOURCES}")"
  if [[ -z "${look_path}" ]]; then
    echo "error: regolith.look.path not set in ${XRESOURCES}" >&2
    exit 1
  fi
  local look_dir="${HOME}/${look_path}"

  local root_file="${look_dir}/root"
  local term_file="${look_dir}/gnome-terminal"
  for f in "${root_file}" "${term_file}"; do
    if [[ ! -f "${f}" ]]; then
      echo "error: look file not found: ${f}" >&2
      exit 1
    fi
  done

  # Load all #define macros from the look's root file (which #includes the
  # rest of the look's Xresource files).
  local -A defs=()
  load_defines defs "${root_file}"

  # Parse gnome-terminal key/value pairs.
  local -A term=()
  local key val
  while IFS= read -r line; do
    [[ "${line}" =~ ^[[:space:]]*! ]] && continue
    [[ "${line}" =~ ^[[:space:]]*$ ]]  && continue
    if [[ "${line}" =~ ^([^:]+):[[:space:]]+(.+)$ ]]; then
      key="${BASH_REMATCH[1]}"
      val="$(resolve defs "${BASH_REMATCH[2]}")"
      term["${key}"]="${val}"
    fi
  done < "${term_file}"

  for n in color{0..15}; do
    if [[ -z "${term[gnome.terminal.${n}]+_}" ]]; then
      echo "error: gnome.terminal.${n} not found in ${term_file}" >&2
      exit 1
    fi
  done

  # Parse font: Pango descriptor "Family Name Size" where the trailing integer
  # or decimal is the point size.
  local family="" size=""
  local font_raw="${term[gnome.terminal.font]:-}"
  if [[ "${font_raw}" =~ ^(.+)[[:space:]]+([0-9]+(\.[0-9]+)?)$ ]]; then
    family="${BASH_REMATCH[1]}"
    size="${BASH_REMATCH[2]}"
    [[ "${size}" != *.* ]] && size="${size}.0"
  elif [[ -n "${font_raw}" ]]; then
    echo "warning: could not parse gnome.terminal.font=${font_raw@Q}; skipping font" >&2
  fi

  local -A c=()
  for n in color{0..15}; do
    c["${n}"]="${term[gnome.terminal.${n}]}"
  done

  cat <<EOF
# Generated by regolith-look-to-alacritty from the active Regolith look.
# Re-run after switching looks or editing the look's palette or font.

[colors.primary]
background = "${c[color0]}"
foreground = "${c[color7]}"

[colors.normal]
black   = "${c[color0]}"
red     = "${c[color1]}"
green   = "${c[color2]}"
yellow  = "${c[color3]}"
blue    = "${c[color4]}"
magenta = "${c[color5]}"
cyan    = "${c[color6]}"
white   = "${c[color7]}"

[colors.bright]
black   = "${c[color8]}"
red     = "${c[color9]}"
green   = "${c[color10]}"
yellow  = "${c[color11]}"
blue    = "${c[color12]}"
magenta = "${c[color13]}"
cyan    = "${c[color14]}"
white   = "${c[color15]}"
EOF

  if [[ -n "${family}" ]]; then
    cat <<EOF

[font]
size = ${size}

[font.normal]
family = "${family}"
EOF
  fi
}

main() {
  mkdir -p "$(dirname "${OUTPUT}")"
  local tmp="${OUTPUT}.tmp"
  generate > "${tmp}"
  mv "${tmp}" "${OUTPUT}"
}
main "$@"
